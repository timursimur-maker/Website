:root {
  --bg: #f7f6f2;
  --text: #111;
  --muted: #666;
  --line: #d8d5cc;
  --max: 1180px;
}

* { box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  margin: 0;
  background: var(--bg);
  color: var(--text);
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  line-height: 1.5;
}

img { display: block; max-width: 100%; }

.hero {
  min-height: 100svh;
  display: grid;
  grid-template-rows: minmax(68svh, 1fr) auto;
  gap: 3rem;
  padding: clamp(1rem, 3vw, 2rem);
}

.hero img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

.claim {
  max-width: var(--max);
  margin: 0 auto 6rem;
  width: 100%;
  font-size: clamp(2.1rem, 7vw, 7rem);
  line-height: 0.98;
  letter-spacing: -0.055em;
  font-weight: 500;
}

.works,
.projects,
.contact {
  width: min(var(--max), calc(100% - 2rem));
  margin: 0 auto;
}

.works { padding: 4rem 0 8rem; }

h1, h2 {
  margin: 0 0 3rem;
  font-size: clamp(0.9rem, 1vw, 1rem);
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.work-grid {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: clamp(1.2rem, 3vw, 3.4rem);
  align-items: start;
}

.work {
  border: 0;
  padding: 0;
  background: transparent;
  cursor: pointer;
  grid-column: span 4;
}

.work img {
  width: 100%;
  height: auto;
  transition: transform 260ms ease, opacity 260ms ease;
}

.work:hover img,
.work:focus-visible img { opacity: 0.84; }

/* Ruhigere, weniger rasterhafte Setzung der Arbeiten */
.work.large { grid-column: span 7; }
.work.wide { grid-column: span 6; }
.work.tall { grid-column: span 4; }

.work:nth-child(1) { grid-column: 1 / span 7; }
.work:nth-child(2) { grid-column: 9 / span 3; margin-top: 7rem; }
.work:nth-child(3) { grid-column: 2 / span 4; margin-top: 4rem; }
.work:nth-child(4) { grid-column: 7 / span 4; margin-top: 1rem; }
.work:nth-child(5) { grid-column: 1 / span 6; margin-top: 3rem; }
.work:nth-child(6) { grid-column: 9 / span 3; margin-top: 8rem; }
.work:nth-child(7) { grid-column: 2 / span 7; margin-top: 2rem; }
.work:nth-child(8) { grid-column: 8 / span 5; margin-top: 5rem; }
.work:nth-child(9) { grid-column: 1 / span 6; margin-top: 2rem; }
.work:nth-child(10) { grid-column: 8 / span 4; margin-top: -1rem; }

.projects {
  padding: 8rem 0 7rem;
  border-top: 1px solid var(--line);
}

.project-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: clamp(2rem, 4vw, 4rem);
}

.project-card {
  padding-top: 1.2rem;
  border-top: 1px solid rgba(17, 17, 17, 0.45);
}

.project-card h3 {
  margin: 0 0 1rem;
  font-size: clamp(1.4rem, 2vw, 2.2rem);
  font-weight: 500;
  letter-spacing: -0.03em;
}

.project-card p {
  margin: 0;
  color: var(--muted);
  font-size: 0.98rem;
  max-width: 32ch;
}

.contact {
  padding: 7rem 0 10rem;
  border-top: 1px solid var(--line);
}

.contact a {
  color: inherit;
  text-decoration: none;
  border-bottom: 1px solid currentColor;
}

.lightbox {
  position: fixed;
  inset: 0;
  z-index: 10;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 2rem;
  background: rgba(247, 246, 242, 0.96);
}

.lightbox.open { display: flex; }

.lightbox img {
  max-height: 82svh;
  max-width: min(1100px, 92vw);
  object-fit: contain;
}

.close {
  position: fixed;
  top: 1rem;
  right: 1rem;
  width: 3rem;
  height: 3rem;
  border: 0;
  background: transparent;
  font-size: 2.5rem;
  line-height: 1;
  cursor: pointer;
}

.caption {
  position: fixed;
  left: 2rem;
  bottom: 1.5rem;
  max-width: 50rem;
  color: var(--text);
  font-size: 0.95rem;
}

@media (max-width: 760px) {
  .hero {
    padding: 0.8rem;
  }

  .hero img {
    height: calc(100svh - 1.6rem);
    object-position: 67% center;
  }

  .claim {
    margin-top: 3.5rem;
    margin-bottom: 4rem;
    font-size: clamp(2.8rem, 18vw, 4.8rem);
    max-width: 9ch;
  }

  .works { padding-top: 2rem; }

  h1, h2 {
    margin-bottom: 2rem;
  }

  .work-grid {
    display: block;
  }

  .work {
    display: block;
    width: 100%;
    margin: 0 0 2.2rem !important;
  }

  .work:nth-child(even) {
    width: 82%;
    margin-left: auto !important;
  }

  .work:nth-child(3n) {
    width: 88%;
    margin-right: auto !important;
  }

  .project-list {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .projects,
  .contact {
    padding: 5rem 0;
  }

  .lightbox {
    padding: 1rem;
    align-items: center;
  }

  .caption {
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
  }
}
